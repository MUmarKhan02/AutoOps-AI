# Copy this file to .env and fill in values before starting.

# Database
POSTGRES_USER=autoops
POSTGRES_PASSWORD=change_me
POSTGRES_DB=autoops_db
DATABASE_URL=postgresql://autoops:change_me@db:5432/autoops_db

# Redis
REDIS_URL=redis://redis:6379/0

# Auth — generate with: openssl rand -hex 32
SECRET_KEY=change_me_generate_with_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Storage
UPLOAD_DIR=/app/storage/uploads
MAX_FILE_SIZE_MB=20

# AI integrations (add real keys when wiring up ai_pipeline.py)
OPENAI_API_KEY=sk-placeholder

# Backend toggle: python | csharp (switch to use ASP.NET Core backend)
ACTIVE_BACKEND=python
